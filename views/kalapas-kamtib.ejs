<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= pageTitle %> - Kalapas</title>
  <link rel="stylesheet" href="/css/style.css?v=<%= Date.now() %>">
  <style>
    .kamtib-wrap { padding: 14px 15px; }
    .kamtib-toolbar {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      align-items: center;
      margin-bottom: 10px;
    }
    .kamtib-toolbar a {
      text-decoration: none;
      color: #fff;
      background: #1a4bb8;
      border: 1px solid rgba(255,255,255,.3);
      border-radius: 6px;
      padding: 7px 11px;
      font-size: 12px;
      font-weight: bold;
      cursor: pointer;
    }
    .kamtib-panel-filter {
      display: flex;
      gap: 6px;
      align-items: center;
      flex-wrap: wrap;
    }
    .kamtib-panel-filter-label {
      font-size: 10px;
      font-weight: 700;
      color: #dbeafe;
      letter-spacing: .2px;
    }
    .kamtib-panel-filter select {
      border: 1px solid rgba(255,255,255,.4);
      border-radius: 4px;
      padding: 4px 8px;
      font-size: 11px;
      font-weight: 700;
      color: #0f172a;
      background: #fff;
    }
    .kamtib-panel-filter input[type="text"] {
      border: 1px solid rgba(255,255,255,.4);
      border-radius: 4px;
      padding: 4px 8px;
      font-size: 11px;
      font-weight: 700;
      color: #0f172a;
      background: #fff;
      min-width: 240px;
    }
    .kamtib-panel-filter button {
      border: 1px solid rgba(255,255,255,.4);
      border-radius: 4px;
      padding: 4px 9px;
      font-size: 11px;
      font-weight: 700;
      color: #1e3a8a;
      background: #eff6ff;
      cursor: pointer;
    }
    .kamtib-panel-filter .reset {
      text-decoration: none;
      border: 1px solid rgba(255,255,255,.4);
      border-radius: 4px;
      padding: 4px 9px;
      font-size: 11px;
      font-weight: 700;
      color: #1e3a8a;
      background: #eff6ff;
    }
    .kamtib-grid {
      display: grid;
      gap: 12px;
      grid-template-columns: 1fr 1fr;
      grid-template-rows: auto auto auto auto;
      grid-template-areas:
        'jadwal bukti'
        'pengawalan pengawalan'
        'strapsel strapsel'
        'registerf registerf';
      min-height: 0;
      align-items: start;
      align-content: start;
    }
    .kamtib-panel {
      min-height: 0;
      display: flex;
      flex-direction: column;
    }
    .kamtib-panel-jadwal { grid-area: jadwal; }
    .kamtib-panel-bukti { grid-area: bukti; }
    .kamtib-panel-pengawalan { grid-area: pengawalan; }
    .kamtib-panel-strapsel { grid-area: strapsel; }
    .kamtib-panel-registerf { grid-area: registerf; }
    .kamtib-panel .panel-header {
      display: flex;
      justify-content: space-between;
      gap: 8px;
      align-items: center;
    }
    .kamtib-panel .panel-content {
      flex: none;
      min-height: 0;
      padding: 0;
    }
    .kamtib-table-scroll {
      flex: none;
      height: auto;
      max-height: 45vh;
      overflow: auto;
      scrollbar-width: none;
    }
    .kamtib-table-scroll::-webkit-scrollbar {
      width: 0;
      height: 0;
    }
    .kamtib-table-scroll thead th {
      position: sticky;
      top: 0;
      z-index: 2;
    }
    .kamtib-panel table th,
    .kamtib-panel table td {
      font-size: 12px;
      padding: 8px 9px;
    }
    .kamtib-empty {
      text-align: center;
      color: #64748b;
      padding: 14px;
      font-weight: bold;
    }
    .kamtib-preview-btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 6px 10px;
      border-radius: 6px;
      border: 1px solid #1d4ed8;
      color: #1d4ed8;
      text-decoration: none;
      font-size: 11px;
      font-weight: bold;
      background: #eff6ff;
    }
    .kamtib-list-cell {
      white-space: pre-line;
      line-height: 1.35;
    }
    @media (max-width: 1100px) {
      .kamtib-grid {
        grid-template-columns: 1fr;
        grid-template-rows: auto;
        grid-template-areas:
          'jadwal'
          'bukti'
          'pengawalan'
          'strapsel'
          'registerf';
        min-height: 0;
      }
      .kamtib-panel .panel-content {
        max-height: 45vh;
      }
      .kamtib-panel-filter {
        width: 100%;
      }
    }
  </style>
</head>
<body class="page-umum">
  <header class="header">
    <div class="header-content">
      <div class="logo-section">
        <div class="logo kalapas-logo">
          <img src="/images/Logo.png" alt="Logo SIMWASPIM" class="kalapas-logo-img">
        </div>
        <div class="header-info">
          <h2>KAMTIB</h2>
          <h3>Ringkasan Keamanan & Ketertiban</h3>
          <p class="address"><%= subtitle %></p>
        </div>
      </div>
    </div>
  </header>

  <div class="kamtib-wrap">
    <div class="kamtib-toolbar">
      <a href="<%= backUrl %>">⬅ Kembali ke Kalapas</a>
      <a href="<%= piketHref %>">🧷 Piket Jaga</a>
    </div>

    <div class="kamtib-grid">
      <div class="panel kamtib-panel kamtib-panel-jadwal">
        <div class="panel-header red">
          <span>JADWAL RAZIA</span>
          <span><%= jadwalRazia.length %> data</span>
        </div>
        <div class="panel-content">
          <div class="table-wrap kamtib-table-scroll">
            <table class="admin-table">
              <thead>
                <tr><th>TANGGAL</th><th>PETUGAS</th><th>DOKUMENTASI</th></tr>
              </thead>
              <tbody>
                <% jadwalRazia.forEach(item => { %>
                <tr>
                  <td><%= formatDateIndo(item.tanggal || '-') %></td>
                  <td><%= item.petugas || '-' %></td>
                  <td>
                    <% if (item.dokumentasiPath) { %>
                    <a href="<%= item.dokumentasiPath %>" target="_blank" rel="noopener noreferrer" class="kamtib-preview-btn">🔍 Preview</a>
                    <% } else { %>
                    -
                    <% } %>
                  </td>
                </tr>
                <% }) %>
                <% if (!jadwalRazia.length) { %>
                <tr><td colspan="3" class="kamtib-empty">Belum ada data</td></tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <div class="panel kamtib-panel kamtib-panel-bukti">
        <div class="panel-header red">
          <span>BARANG BUKTI RAZIA</span>
          <span><%= barangBuktiRazia.length %> data</span>
        </div>
        <div class="panel-content">
          <div class="table-wrap kamtib-table-scroll">
            <table class="admin-table">
              <thead>
                <tr><th>PEMILIK</th><th>KAMAR/BLOK</th><th>FOTO</th></tr>
              </thead>
              <tbody>
                <% barangBuktiRazia.forEach(item => { %>
                <tr>
                  <td><%= item.pemilik || '-' %></td>
                  <td><%= item.kamarBlok || '-' %></td>
                  <td>
                    <% if (item.fotoPath) { %>
                    <a href="<%= item.fotoPath %>" target="_blank" rel="noopener noreferrer" class="kamtib-preview-btn">🔍 Preview</a>
                    <% } else { %>
                    -
                    <% } %>
                  </td>
                </tr>
                <% }) %>
                <% if (!barangBuktiRazia.length) { %>
                <tr><td colspan="3" class="kamtib-empty">Belum ada data</td></tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <div class="panel kamtib-panel kamtib-panel-pengawalan">
        <div class="panel-header red">
          <span>GIAT PENGAWALAN</span>
          <form method="GET" action="/kalapas/table/kamtib" class="kamtib-panel-filter">
            <input type="hidden" name="strapselSearch" value="<%= strapselSearch || '' %>">
            <input type="hidden" name="registerFSearch" value="<%= registerFSearch || '' %>">
            <span class="kamtib-panel-filter-label">Filter Giat Pengawalan</span>
            <select name="month" aria-label="Filter bulan pengawalan">
              <% monthOptions.forEach(opt => { %>
                <option value="<%= opt.value %>" <%= opt.value === selectedMonth ? 'selected' : '' %>><%= opt.label %></option>
              <% }) %>
            </select>
            <select name="year" aria-label="Filter tahun pengawalan">
              <% yearOptions.forEach(year => { %>
                <option value="<%= year %>" <%= String(year) === String(selectedYear) ? 'selected' : '' %>><%= year %></option>
              <% }) %>
            </select>
            <button type="submit">Terapkan</button>
            <span><%= pengawalanList.length %> data</span>
          </form>
        </div>
        <div class="panel-content">
          <div class="table-wrap kamtib-table-scroll">
            <table class="admin-table">
              <thead>
                <tr><th>TANGGAL</th><th>NAMA WBP</th><th>PETUGAS</th><th>KETERANGAN</th><th>DOKUMENTASI</th></tr>
              </thead>
              <tbody>
                <% pengawalanList.forEach(item => { %>
                <tr>
                  <td><%= formatDateIndo(item.tanggal || '-') %></td>
                  <td class="kamtib-list-cell"><%= item.namaWbp || '-' %></td>
                  <td class="kamtib-list-cell"><%= item.petugas || '-' %></td>
                  <td><%= item.keterangan || '-' %></td>
                  <td>
                    <% if (item.dokumentasiPath) { %>
                    <a href="<%= item.dokumentasiPath %>" target="_blank" rel="noopener noreferrer" class="kamtib-preview-btn">🔍 View</a>
                    <% } else { %>
                    -
                    <% } %>
                  </td>
                </tr>
                <% }) %>
                <% if (!pengawalanList.length) { %>
                <tr><td colspan="5" class="kamtib-empty">Belum ada data pada filter ini</td></tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <div class="panel kamtib-panel kamtib-panel-strapsel">
        <div class="panel-header red">
          <span>DATA STRAPSEL</span>
          <form method="GET" action="/kalapas/table/kamtib" class="kamtib-panel-filter">
            <input type="hidden" name="month" value="<%= selectedMonth %>">
            <input type="hidden" name="year" value="<%= selectedYear %>">
            <input type="hidden" name="registerFSearch" value="<%= registerFSearch || '' %>">
            <span class="kamtib-panel-filter-label">Pencarian Strapsel</span>
            <input type="text" name="strapselSearch" value="<%= strapselSearch || '' %>" placeholder="Cari nama, blok, permasalahan, barang bukti...">
            <button type="submit">Terapkan</button>
            <a href="/kalapas/table/kamtib?month=<%= selectedMonth %>&year=<%= selectedYear %><%= registerFSearch ? ('&registerFSearch=' + encodeURIComponent(registerFSearch)) : '' %>" class="reset">Reset</a>
            <span><%= strapselList.length %> data</span>
          </form>
        </div>
        <div class="panel-content">
          <div class="table-wrap kamtib-table-scroll">
            <table class="admin-table">
              <thead>
                <tr>
                  <th>NAMA WBP</th><th>BLOK HUNIAN</th><th>TANGGAL MASUK</th><th>EKSPIRASI</th><th>PERMASALAHAN</th><th>BARANG BUKTI</th><th>DOKUMENTASI</th>
                </tr>
              </thead>
              <tbody>
                <% strapselList.forEach(item => { %>
                <tr>
                  <td><%= item.namaWbp || '-' %></td>
                  <td><%= item.blokHunian || '-' %></td>
                  <td><%= formatDateIndo(item.tanggalMasukStrapsel || '-') %></td>
                  <td><%= formatDateIndo(item.ekspirasi || '-') %></td>
                  <td><%= item.permasalahan || '-' %></td>
                  <td><%= item.barangBukti || '-' %></td>
                  <td>
                    <% if (item.dokumentasiPath) { %>
                    <a href="<%= item.dokumentasiPath %>" target="_blank" rel="noopener noreferrer" class="kamtib-preview-btn">🔍 Preview</a>
                    <% } else { %>
                    -
                    <% } %>
                  </td>
                </tr>
                <% }) %>
                <% if (!strapselList.length) { %>
                <tr><td colspan="7" class="kamtib-empty">Belum ada data</td></tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <div class="panel kamtib-panel kamtib-panel-registerf">
        <div class="panel-header red">
          <span>REGISTER F</span>
          <form method="GET" action="/kalapas/table/kamtib" class="kamtib-panel-filter">
            <input type="hidden" name="month" value="<%= selectedMonth %>">
            <input type="hidden" name="year" value="<%= selectedYear %>">
            <input type="hidden" name="strapselSearch" value="<%= strapselSearch || '' %>">
            <span class="kamtib-panel-filter-label">Pencarian Register F</span>
            <input type="text" name="registerFSearch" value="<%= registerFSearch || '' %>" placeholder="Cari no register, nama, pelanggaran, hukuman...">
            <button type="submit">Terapkan</button>
            <a href="/kalapas/table/kamtib?month=<%= selectedMonth %>&year=<%= selectedYear %><%= strapselSearch ? ('&strapselSearch=' + encodeURIComponent(strapselSearch)) : '' %>" class="reset">Reset</a>
            <span><%= registerFList.length %> data</span>
          </form>
        </div>
        <div class="panel-content">
          <div class="table-wrap kamtib-table-scroll">
            <table class="admin-table">
              <thead>
                <tr>
                  <th rowspan="2">NO REGISTER</th>
                  <th rowspan="2">NAMA WBP</th>
                  <th rowspan="2">JENIS PELANGGARAN</th>
                  <th rowspan="2">TANGGAL PELANGGARAN</th>
                  <th rowspan="2">LAMA HUKUMAN</th>
                  <th colspan="2">HUKUMAN TATA TERTIB</th>
                  <th rowspan="2">KETERANGAN</th>
                </tr>
                <tr>
                  <th>MULAI DARI</th>
                  <th>SAMPAI DENGAN</th>
                </tr>
              </thead>
              <tbody>
                <% registerFList.forEach(item => { %>
                <tr>
                  <td><%= item.noRegister || '-' %></td>
                  <td><%= item.namaWbp || '-' %></td>
                  <td><%= item.jenisPelanggaran || '-' %></td>
                  <td><%= formatDateIndo(item.tanggalPelanggaran || '-') %></td>
                  <td><%= item.lamaHukuman || '-' %></td>
                  <td><%= formatDateIndo(item.hukumanMulai || '-') %></td>
                  <td><%= formatDateIndo(item.hukumanSelesai || '-') %></td>
                  <td><%= item.keterangan || '-' %></td>
                </tr>
                <% }) %>
                <% if (!registerFList.length) { %>
                <tr><td colspan="8" class="kamtib-empty">Belum ada data</td></tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>
</body>
</html>
