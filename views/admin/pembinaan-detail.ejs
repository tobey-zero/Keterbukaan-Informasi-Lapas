<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Detail Pembinaan – Admin Lapas</title>
  <link rel="stylesheet" href="/css/admin.css">
  <style>
    .status-overdue {
      background: #ef4444;
      color: #ffffff;
      font-weight: 700;
    }
  </style>
</head>
<body>
<div class="admin-wrapper">
  <%- include('_sidebar') %>
  <div class="main-content">
    <div class="topbar">
      <div class="topbar-title"><h2>📝 Detail Pentahapan Pembinaan</h2><p>Kelola detail jadwal & remisi WBP</p></div>
      <div class="topbar-actions"><a href="/" target="_blank" class="btn-public">🌐 Lihat Publik</a></div>
    </div>
    <div class="content-area">
      <% if (success) { %><div class="alert alert-success">✅ Data berhasil disimpan.</div><% } %>

      <!-- Form Tambah -->
      <div class="card">
        <div class="card-header"><h3>➕ Tambah Detail</h3></div>
        <div class="card-body">
          <form method="POST" action="/admin/pembinaan-detail/add">
            <div class="form-grid col-4" style="margin-bottom:12px;">
              <div class="form-group">
                <label>No. Registrasi</label>
                <input type="text" name="no_reg" placeholder="cth: BI.15-PK/PD/2023" required>
              </div>
              <div class="form-group">
                <label>Nama WBP</label>
                <input type="text" name="nama_wbp" placeholder="Nama lengkap" required>
              </div>
              <div class="form-group">
                <label>Jenis Kejahatan</label>
                <input type="text" name="jenis_kejahatan" placeholder="cth: Narkotika">
              </div>
              <div class="form-group">
                <label>Blok/Kamar</label>
                <input type="text" name="blok_kamar" placeholder="cth: BLOK A / KAMAR 01">
              </div>
              <div class="form-group">
                <label>Tanggal 1/3</label>
                <input type="text" name="tanggal1" placeholder="cth: 15 Oct 2020">
              </div>
              <div class="form-group">
                <label>Tanggal 1/2</label>
                <input type="text" name="tanggal3" placeholder="cth: 15 Oct 2020">
              </div>
              <div class="form-group">
                <label>Tanggal 2/3</label>
                <input type="text" name="tanggal2" placeholder="cth: 15 Oct 2020">
              </div>
              <div class="form-group">
                <label>Tanggal Ekspirasi Akhir</label>
                <input type="text" name="tanggal4" placeholder="cth: 28 Dec 2023">
              </div>
              <div class="form-group">
                <label>Total Remisi</label>
                <input type="text" name="total_remisi" placeholder="cth: 4 Bulan 15 Hari">
              </div>
              <div class="form-group">
                <label>Keterangan</label>
                <input type="hidden" name="keterangan" id="keterangan_add_final">
                <select id="keterangan_add_select" data-keterangan-select="add">
                  <option value="Aktif Tempat Ibadah">Aktif Tempat Ibadah</option>
                  <option value="Pramuka">Pramuka</option>
                  <option value="Pekerja/Tamping">Pekerja/Tamping</option>
                  <option value="__custom__">Custom (isi manual)</option>
                </select>
                <input type="text" id="keterangan_add_custom" data-keterangan-custom="add" placeholder="Isi keterangan manual" style="margin-top:8px; display:none;">
              </div>
              <div class="form-group">
                <label>Status Integrasi</label>
                <select name="status_integrasi" required>
                  <option value="">-- Pilih Status --</option>
                  <option value="-">-</option>
                  <option value="Menunggu SK">Menunggu SK</option>
                  <option value="Sudah ada hasil SK">Sudah ada hasil SK</option>
                  <option value="Ditolak">Ditolak</option>
                  <option value="Proses Verifikasi">Proses Verifikasi</option>
                </select>
              </div>
            </div>
            <button type="submit" class="btn btn-primary btn-sm">➕ Tambah</button>
          </form>
        </div>
      </div>

      <!-- Form Edit -->
      <% if (edit) { %>
      <div class="edit-panel">
        <h4>✏️ Edit Detail (ID: <%= edit.id %>)</h4>
        <form method="POST" action="/admin/pembinaan-detail/<%= edit.id %>/update">
          <% const keteranganPresets = ['Aktif Tempat Ibadah','Pramuka','Pekerja/Tamping']; %>
          <% const isCustomKeterangan = edit.keterangan && !keteranganPresets.includes(edit.keterangan); %>
          <div class="form-grid col-4" style="margin-bottom:12px;">
            <div class="form-group">
              <label>No. Registrasi</label>
              <input type="text" name="no_reg" value="<%= edit.no_reg %>" required>
            </div>
            <div class="form-group">
              <label>Nama WBP</label>
              <input type="text" name="nama_wbp" value="<%= edit.nama_wbp %>" required>
            </div>
            <div class="form-group">
              <label>Jenis Kejahatan</label>
              <input type="text" name="jenis_kejahatan" value="<%= edit.jenis_kejahatan || '' %>">
            </div>
            <div class="form-group">
              <label>Blok/Kamar</label>
              <input type="text" name="blok_kamar" value="<%= edit.blok_kamar || '' %>">
            </div>
            <div class="form-group">
              <label>Tanggal 1/3</label>
              <input type="text" name="tanggal1" value="<%= edit.tanggal1 || '' %>">
            </div>
            <div class="form-group">
              <label>Tanggal 1/2</label>
              <input type="text" name="tanggal3" value="<%= edit.tanggal3 || '' %>">
            </div>
            <div class="form-group">
              <label>Tanggal 2/3</label>
              <input type="text" name="tanggal2" value="<%= edit.tanggal2 || '' %>">
            </div>
            <div class="form-group">
              <label>Tanggal Ekspirasi Akhir</label>
              <input type="text" name="tanggal4" value="<%= edit.tanggal4 || '' %>">
            </div>
            <div class="form-group">
              <label>Total Remisi</label>
              <input type="text" name="total_remisi" value="<%= edit.total_remisi || '' %>">
            </div>
            <div class="form-group">
              <label>Keterangan</label>
              <input type="hidden" name="keterangan" id="keterangan_edit_final" value="<%= edit.keterangan || '' %>">
              <select id="keterangan_edit_select" data-keterangan-select="edit">
                <% keteranganPresets.forEach(k => { %>
                <option value="<%= k %>" <%= edit.keterangan===k?'selected':'' %>><%= k %></option>
                <% }) %>
                <option value="__custom__" <%= isCustomKeterangan ? 'selected' : '' %>>Custom (isi manual)</option>
              </select>
              <input type="text" id="keterangan_edit_custom" data-keterangan-custom="edit" placeholder="Isi keterangan manual" value="<%= isCustomKeterangan ? edit.keterangan : '' %>" style="margin-top:8px; display:none;">
            </div>
            <div class="form-group">
              <label>Status Integrasi</label>
              <select name="status_integrasi" required>
                <% ['-','Menunggu SK','Sudah ada hasil SK','Ditolak','Proses Verifikasi'].forEach(s => { %>
                <option value="<%= s %>" <%= edit.status_integrasi===s?'selected':'' %>><%= s %></option>
                <% }) %>
              </select>
            </div>
          </div>
          <div style="display:flex;gap:8px;">
            <button type="submit" class="btn btn-success btn-sm">💾 Simpan</button>
            <a href="/admin/pembinaan-detail" class="btn btn-secondary btn-sm">✕ Batal</a>
          </div>
        </form>
      </div>
      <% } %>

      <!-- Tabel -->
      <div class="card">
        <div class="card-header"><h3>Data Detail Pembinaan (<%= list.length %> entri)</h3></div>
        <div class="card-body" style="padding:0;">
          <div class="table-wrap">
            <table class="admin-table">
              <thead>
                <tr>
                  <th>#</th><th>No. Reg</th><th>Nama WBP</th>
                  <th>Jenis Kejahatan</th><th>Blok/Kamar</th><th>Tgl 1/3</th><th>Tgl 1/2</th><th>Tgl 2/3</th><th>Ekspirasi</th><th>Total Remisi</th>
                  <th>Ket.</th><th>Status Integrasi</th><th>Aksi</th>
                </tr>
              </thead>
              <tbody>
                <% list.forEach((item, i) => { %>
                <tr>
                  <td><%= i+1 %></td>
                  <td><%= item.no_reg %></td>
                  <td><%= item.nama_wbp %></td>
                  <td><%= item.jenis_kejahatan||'-' %></td>
                  <td><%= item.blok_kamar||'-' %></td>
                  <td><%= formatDateIndo(item.tanggal1||'-') %></td>
                  <td><%= formatDateIndo(item.tanggal3||'-') %></td>
                  <td><%= formatDateIndo(item.tanggal2||'-') %></td>
                  <td><%= formatDateIndo(item.tanggal4||'-') %></td>
                  <td><%= item.total_remisi||'-' %></td>
                  <td><%= item.keterangan||'-' %></td>
                  <td class="<%= item.is_status_overdue ? 'status-overdue' : '' %>"><%= item.status_integrasi||'-' %></td>
                  <td>
                    <div class="actions">
                      <a href="/admin/pembinaan-detail?edit=<%= item.id %>" class="btn btn-warning btn-xs">✏️</a>
                      <form method="POST" action="/admin/pembinaan-detail/<%= item.id %>/delete" style="display:inline" onsubmit="return confirm('Hapus?')">
                        <button class="btn btn-danger btn-xs">🗑</button>
                      </form>
                    </div>
                  </td>
                  <% if (!list.length) { %><tr><td colspan="13" style="text-align:center;color:#aaa;padding:20px;">Belum ada data</td></tr><% } %>
                <% }) %>
                <% if (!list.length) { %><tr><td colspan="12" style="text-align:center;color:#aaa;padding:20px;">Belum ada data</td></tr><% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
<script>
  (function () {
    function bindKeterangan(mode) {
      var select = document.querySelector('[data-keterangan-select="' + mode + '"]');
      var customInput = document.querySelector('[data-keterangan-custom="' + mode + '"]');
      var hiddenInput = document.getElementById('keterangan_' + mode + '_final');
      if (!select || !hiddenInput) return;

      function syncValue() {
        var isCustom = select.value === '__custom__';
        if (customInput) {
          customInput.style.display = isCustom ? 'block' : 'none';
          customInput.required = isCustom;
        }
        hiddenInput.value = isCustom
          ? ((customInput && customInput.value) ? customInput.value.trim() : '')
          : select.value;
      }

      select.addEventListener('change', syncValue);
      if (customInput) customInput.addEventListener('input', syncValue);
      syncValue();

      var form = select.closest('form');
      if (form) {
        form.addEventListener('submit', function () {
          syncValue();
        });
      }
    }

    bindKeterangan('add');
    bindKeterangan('edit');
  })();
</script>
</body>
</html>
