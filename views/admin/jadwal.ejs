<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Jadwal Kegiatan – Admin Lapas</title>
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body>
<div class="admin-wrapper">
  <%- include('_sidebar') %>
  <div class="main-content">
    <div class="topbar">
      <div class="topbar-title"><h2>📅 Jadwal Kegiatan</h2><p>Kelola jadwal kegiatan pembinaan</p></div>
      <div class="topbar-actions"><a href="/" target="_blank" class="btn-public">🌐 Lihat Publik</a></div>
    </div>
    <div class="content-area">
      <% if (success) { %><div class="alert alert-success">✅ Data berhasil disimpan.</div><% } %>

      <div class="card">
        <div class="card-header"><h3>➕ Tambah Jadwal</h3></div>
        <div class="card-body">
          <form method="POST" action="/admin/jadwal/add">
            <div class="form-grid col-3" style="margin-bottom:12px;">
              <div class="form-group">
                <label>Kegiatan</label>
                <input type="text" name="kegiatan" placeholder="Nama kegiatan" required>
              </div>
              <div class="form-group">
                <label>Hari / Lokasi (Kolom Selasa)</label>
                <input type="text" name="selasa" placeholder="cth: Relaksai Jiwa">
              </div>
              <div class="form-group">
                <label>Waktu / Tempat (Kolom Rabu)</label>
                <input type="text" name="rabu" placeholder="cth: Lapangan Lapas">
              </div>
            </div>
            <button type="submit" class="btn btn-primary btn-sm">➕ Tambah</button>
          </form>
        </div>
      </div>

      <% if (edit) { %>
      <div class="edit-panel">
        <h4>✏️ Edit Jadwal (ID: <%= edit.id %>)</h4>
        <form method="POST" action="/admin/jadwal/<%= edit.id %>/update">
          <div class="form-grid col-3" style="margin-bottom:12px;">
            <div class="form-group">
              <label>Kegiatan</label>
              <input type="text" name="kegiatan" value="<%= edit.kegiatan %>" required>
            </div>
            <div class="form-group">
              <label>Kolom Selasa</label>
              <input type="text" name="selasa" value="<%= edit.selasa || '' %>">
            </div>
            <div class="form-group">
              <label>Kolom Rabu</label>
              <input type="text" name="rabu" value="<%= edit.rabu || '' %>">
            </div>
          </div>
          <div style="display:flex;gap:8px;">
            <button type="submit" class="btn btn-success btn-sm">💾 Simpan</button>
            <a href="/admin/jadwal" class="btn btn-secondary btn-sm">✕ Batal</a>
          </div>
        </form>
      </div>
      <% } %>

      <div class="card">
        <div class="card-header"><h3>Daftar Jadwal (<%= list.length %> item)</h3></div>
        <div class="card-body" style="padding:0;">
          <div class="table-wrap">
            <table class="admin-table">
              <thead><tr><th>#</th><th>Kegiatan</th><th>Kolom Selasa</th><th>Kolom Rabu</th><th>Aksi</th></tr></thead>
              <tbody>
                <% list.forEach((item, i) => { %>
                <tr>
                  <td><%= i+1 %></td>
                  <td><%= item.kegiatan %></td>
                  <td><%= item.selasa||'-' %></td>
                  <td><%= item.rabu||'-' %></td>
                  <td>
                    <div class="actions">
                      <a href="/admin/jadwal?edit=<%= item.id %>" class="btn btn-warning btn-xs">✏️ Edit</a>
                      <form method="POST" action="/admin/jadwal/<%= item.id %>/delete" style="display:inline" onsubmit="return confirm('Hapus?')">
                        <button class="btn btn-danger btn-xs">🗑 Hapus</button>
                      </form>
                    </div>
                  </td>
                </tr>
                <% }) %>
                <% if (!list.length) { %><tr><td colspan="5" style="text-align:center;color:#aaa;padding:20px;">Belum ada data</td></tr><% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
</body>
</html>
