<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>GIIATJA – Admin Lapas</title>
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body>
<div class="admin-wrapper">
  <%- include('_sidebar') %>
  <div class="main-content">
    <div class="topbar">
      <div class="topbar-title"><h2>🏭 GIIATJA (Kegiatan Kerja)</h2><p>Kelola data kegiatan kerja, pelatihan, PNBP, dan premi WBP</p></div>
      <div class="topbar-actions"><a href="/kalapas/table/giiatja" target="_blank" class="btn-public">🧭 Lihat Tabel Kalapas</a></div>
    </div>

    <div class="content-area">
      <% if (success) { %><div class="alert alert-success">✅ Data GIIATJA berhasil disimpan.</div><% } %>

      <div class="card">
        <div class="card-header"><h3>⚙️ Pengaturan Judul Tabel</h3></div>
        <div class="card-body">
          <form method="POST" action="/admin/giiatja/settings/update">
            <div class="form-grid col-4" style="margin-bottom:12px;">
              <div class="form-group">
                <label>Tahun PNBP</label>
                <input type="text" name="giiatja_pnbp_tahun" value="<%= pnbpTahun || '' %>" placeholder="cth: 2026">
              </div>
              <div class="form-group">
                <label>Periode Bulan Premi</label>
                <input type="text" name="giiatja_premi_periode_bulan" value="<%= premiPeriodeBulan || '' %>" placeholder="cth: APRIL 2026">
              </div>
            </div>
            <button type="submit" class="btn btn-primary btn-sm">💾 Simpan Pengaturan</button>
          </form>
        </div>
      </div>

      <div class="card">
        <div class="card-header"><h3>➕ Master Kategori Kegiatan</h3></div>
        <div class="card-body">
          <form method="POST" action="/admin/giiatja/kategori/add">
            <div class="form-grid col-4" style="margin-bottom:12px;">
              <div class="form-group"><label>Kategori</label><input type="text" name="kategori" required placeholder="cth: A (AREA DALAM)"></div>
              <div class="form-group"><label>Urutan</label><input type="number" min="1" name="sort_order" value="1"></div>
            </div>
            <button type="submit" class="btn btn-primary btn-sm">➕ Tambah Kategori</button>
          </form>
        </div>
      </div>

      <% if (editKategori) { %>
      <div class="edit-panel">
        <h4>✏️ Edit Kategori (ID: <%= editKategori.id %>)</h4>
        <form method="POST" action="/admin/giiatja/kategori/<%= editKategori.id %>/update">
          <div class="form-grid col-4" style="margin-bottom:12px;">
            <div class="form-group"><label>Kategori</label><input type="text" name="kategori" value="<%= editKategori.kategori || '' %>" required></div>
            <div class="form-group"><label>Urutan</label><input type="number" min="1" name="sort_order" value="<%= editKategori.sort_order || 1 %>"></div>
          </div>
          <div style="display:flex;gap:8px;">
            <button type="submit" class="btn btn-success btn-sm">💾 Simpan</button>
            <a href="/admin/giiatja" class="btn btn-secondary btn-sm">✕ Batal</a>
          </div>
        </form>
      </div>
      <% } %>

      <div class="card">
        <div class="card-header"><h3>Daftar Kategori (<%= kegiatanCategories.length %> data)</h3></div>
        <div class="card-body" style="padding:0;">
          <div class="table-wrap">
            <table class="admin-table">
              <thead><tr><th>#</th><th>Kategori</th><th>Urutan</th><th>Aksi</th></tr></thead>
              <tbody>
                <% kegiatanCategories.forEach((item, i) => { %>
                <tr>
                  <td><%= i + 1 %></td>
                  <td><%= item.kategori || '-' %></td>
                  <td><%= item.sort_order || '-' %></td>
                  <td>
                    <div class="actions">
                      <a href="/admin/giiatja?editKategori=<%= item.id %>" class="btn btn-warning btn-xs">✏️</a>
                      <form method="POST" action="/admin/giiatja/kategori/<%= item.id %>/delete" style="display:inline" onsubmit="return confirm('Hapus kategori ini beserta detail kegiatannya?')">
                        <button class="btn btn-danger btn-xs">🗑</button>
                      </form>
                    </div>
                  </td>
                </tr>
                <% }) %>
                <% if (!kegiatanCategories.length) { %><tr><td colspan="4" style="text-align:center;color:#aaa;padding:20px;">Belum ada data</td></tr><% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <div class="card">
        <div class="card-header"><h3>➕ Detail Kegiatan per Peserta</h3></div>
        <div class="card-body">
          <form method="POST" action="/admin/giiatja/kegiatan/add" enctype="multipart/form-data">
            <div class="form-grid col-4" style="margin-bottom:12px;">
              <div class="form-group">
                <label>Kategori</label>
                <select name="kegiatan_id" required>
                  <option value="">-- Pilih Kategori --</option>
                  <% kegiatanCategories.forEach(item => { %>
                    <option value="<%= item.id %>"><%= item.kategori %></option>
                  <% }) %>
                </select>
              </div>
              <div class="form-group"><label>Urutan</label><input type="number" min="1" name="sort_order" value="1"></div>
              <div class="form-group"><label>Jenis Kegiatan</label><input type="text" name="jenis_kegiatan" required placeholder="cth: PANGKAS"></div>
              <div class="form-group"><label>Nama Peserta</label><textarea name="peserta_kegiatan" rows="3" required placeholder="cth:
WBP A.N. A
WBP B.N. B"></textarea></div>
              <div class="form-group"><label>Pengawas</label><textarea name="pengawas" rows="3" placeholder="cth:
PETUGAS A
PETUGAS B"></textarea></div>
              <div class="form-group"><label>Dokumentasi (opsional)</label><input type="file" name="dokumentasi" accept="image/*"></div>
            </div>
            <button type="submit" class="btn btn-primary btn-sm">➕ Tambah Detail</button>
          </form>
        </div>
      </div>

      <% if (editKegiatan) { %>
      <div class="edit-panel">
        <h4>✏️ Edit Detail Kegiatan (ID: <%= editKegiatan.id %>)</h4>
        <form method="POST" action="/admin/giiatja/kegiatan/<%= editKegiatan.id %>/update" enctype="multipart/form-data">
          <div class="form-grid col-4" style="margin-bottom:12px;">
            <div class="form-group">
              <label>Kategori</label>
              <select name="kegiatan_id" required>
                <% kegiatanCategories.forEach(item => { %>
                  <option value="<%= item.id %>" <%= Number(editKegiatan.kegiatan_id)===Number(item.id)?'selected':'' %>><%= item.kategori %></option>
                <% }) %>
              </select>
            </div>
            <div class="form-group"><label>Urutan</label><input type="number" min="1" name="sort_order" value="<%= editKegiatan.sort_order || 1 %>"></div>
            <div class="form-group"><label>Jenis Kegiatan</label><input type="text" name="jenis_kegiatan" value="<%= editKegiatan.jenis_kegiatan || '' %>" required></div>
            <div class="form-group"><label>Nama Peserta</label><textarea name="peserta_kegiatan" rows="3" required><%= editKegiatan.peserta_kegiatan || '' %></textarea></div>
            <div class="form-group"><label>Pengawas</label><textarea name="pengawas" rows="3"><%= editKegiatan.pengawas || '' %></textarea></div>
            <div class="form-group"><label>Dokumentasi Baru (opsional)</label><input type="file" name="dokumentasi" accept="image/*"></div>
          </div>
          <div style="display:flex;gap:8px;">
            <button type="submit" class="btn btn-success btn-sm">💾 Simpan</button>
            <a href="/admin/giiatja" class="btn btn-secondary btn-sm">✕ Batal</a>
          </div>
        </form>
      </div>
      <% } %>

      <div class="card">
        <div class="card-header"><h3>Daftar Detail Kegiatan (<%= kegiatanList.length %> data)</h3></div>
        <div class="card-body" style="padding:0;">
          <div class="table-wrap">
            <table class="admin-table">
              <thead><tr><th>#</th><th>Kategori</th><th>Jenis Kegiatan</th><th>Nama Peserta</th><th>Pengawas</th><th>Dokumentasi</th><th>Aksi</th></tr></thead>
              <tbody>
                <% kegiatanList.forEach((item, i) => { %>
                <tr>
                  <td><%= i + 1 %></td>
                  <td><%= item.kategori || '-' %></td>
                  <td><%= item.jenis_kegiatan || '-' %></td>
                  <td>
                    <% const pesertaLines = String(item.peserta_kegiatan || '').split(/\r?\n/).map(line => line.trim()).filter(Boolean); %>
                    <% if (pesertaLines.length) { %>
                      <ol style="margin:0; padding-left:18px; white-space:normal;">
                        <% pesertaLines.forEach((line) => { %>
                          <li><%= line %></li>
                        <% }) %>
                      </ol>
                    <% } else { %>
                      -
                    <% } %>
                  </td>
                  <td>
                    <% const pengawasLines = String(item.pengawas || '').split(/\r?\n/).map(line => line.trim()).filter(Boolean); %>
                    <% if (pengawasLines.length) { %>
                      <ol style="margin:0; padding-left:18px; white-space:normal;">
                        <% pengawasLines.forEach((line) => { %>
                          <li><%= line %></li>
                        <% }) %>
                      </ol>
                    <% } else { %>
                      -
                    <% } %>
                  </td>
                  <td>
                    <% if (item.dokumentasi_path) { %>
                      <a href="<%= item.dokumentasi_path %>" target="_blank" class="btn btn-secondary btn-xs">🔍 Lihat</a>
                    <% } else { %>-<% } %>
                  </td>
                  <td>
                    <div class="actions">
                      <a href="/admin/giiatja?editKegiatan=<%= item.id %>" class="btn btn-warning btn-xs">✏️</a>
                      <form method="POST" action="/admin/giiatja/kegiatan/<%= item.id %>/delete" style="display:inline" onsubmit="return confirm('Hapus detail ini?')">
                        <button class="btn btn-danger btn-xs">🗑</button>
                      </form>
                    </div>
                  </td>
                </tr>
                <% }) %>
                <% if (!kegiatanList.length) { %><tr><td colspan="7" style="text-align:center;color:#aaa;padding:20px;">Belum ada data</td></tr><% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <div class="card">
        <div class="card-header"><h3>➕ Tabel Pelatihan Bersertifikat</h3></div>
        <div class="card-body">
          <form method="POST" action="/admin/giiatja/pelatihan/add" enctype="multipart/form-data">
            <div class="form-grid col-4" style="margin-bottom:12px;">
              <div class="form-group"><label>No Registrasi</label><input type="text" name="no_registrasi"></div>
              <div class="form-group"><label>Nama WBP</label><input type="text" name="nama_wbp" required></div>
              <div class="form-group"><label>Jenis Pelatihan</label><input type="text" name="jenis_pelatihan"></div>
              <div class="form-group"><label>Tanggal Pelaksanaan</label><input type="text" name="tanggal_pelaksanaan" placeholder="cth: 18 April 2026"></div>
              <div class="form-group"><label>Instruktur</label><input type="text" name="instruktur"></div>
              <div class="form-group"><label>Foto Sertifikat</label><input type="file" name="poto_sertifikat" accept="image/*"></div>
              <div class="form-group" style="grid-column:span 2;"><label>Keterangan</label><input type="text" name="keterangan"></div>
            </div>
            <button type="submit" class="btn btn-primary btn-sm">➕ Tambah Pelatihan</button>
          </form>
        </div>
      </div>

      <% if (editPelatihan) { %>
      <div class="edit-panel">
        <h4>✏️ Edit Pelatihan (ID: <%= editPelatihan.id %>)</h4>
        <form method="POST" action="/admin/giiatja/pelatihan/<%= editPelatihan.id %>/update" enctype="multipart/form-data">
          <div class="form-grid col-4" style="margin-bottom:12px;">
            <div class="form-group"><label>No Registrasi</label><input type="text" name="no_registrasi" value="<%= editPelatihan.no_registrasi || '' %>"></div>
            <div class="form-group"><label>Nama WBP</label><input type="text" name="nama_wbp" value="<%= editPelatihan.nama_wbp || '' %>" required></div>
            <div class="form-group"><label>Jenis Pelatihan</label><input type="text" name="jenis_pelatihan" value="<%= editPelatihan.jenis_pelatihan || '' %>"></div>
            <div class="form-group"><label>Tanggal Pelaksanaan</label><input type="text" name="tanggal_pelaksanaan" value="<%= editPelatihan.tanggal_pelaksanaan || '' %>"></div>
            <div class="form-group"><label>Instruktur</label><input type="text" name="instruktur" value="<%= editPelatihan.instruktur || '' %>"></div>
            <div class="form-group"><label>Foto Sertifikat Baru</label><input type="file" name="poto_sertifikat" accept="image/*"></div>
            <div class="form-group" style="grid-column:span 2;"><label>Keterangan</label><input type="text" name="keterangan" value="<%= editPelatihan.keterangan || '' %>"></div>
          </div>
          <div style="display:flex;gap:8px;">
            <button type="submit" class="btn btn-success btn-sm">💾 Simpan</button>
            <a href="/admin/giiatja" class="btn btn-secondary btn-sm">✕ Batal</a>
          </div>
        </form>
      </div>
      <% } %>

      <div class="card">
        <div class="card-header"><h3>Daftar Pelatihan Bersertifikat (<%= pelatihanList.length %> data)</h3></div>
        <div class="card-body" style="padding:0;">
          <div class="table-wrap">
            <table class="admin-table">
              <thead><tr><th>No</th><th>No Registrasi</th><th>Nama WBP</th><th>Jenis Pelatihan</th><th>Tanggal</th><th>Instruktur</th><th>Foto Sertifikat</th><th>Keterangan</th><th>Aksi</th></tr></thead>
              <tbody>
                <% pelatihanList.forEach((item, i) => { %>
                <tr>
                  <td><%= i + 1 %></td>
                  <td><%= item.no_registrasi || '-' %></td>
                  <td><%= item.nama_wbp || '-' %></td>
                  <td><%= item.jenis_pelatihan || '-' %></td>
                  <td><%= formatDateIndo(item.tanggal_pelaksanaan || '-') %></td>
                  <td><%= item.instruktur || '-' %></td>
                  <td>
                    <% if (item.poto_sertifikat_path) { %>
                      <a href="<%= item.poto_sertifikat_path %>" target="_blank" class="btn btn-secondary btn-xs">🔍 Lihat</a>
                    <% } else { %>-<% } %>
                  </td>
                  <td><%= item.keterangan || '-' %></td>
                  <td>
                    <div class="actions">
                      <a href="/admin/giiatja?editPelatihan=<%= item.id %>" class="btn btn-warning btn-xs">✏️</a>
                      <form method="POST" action="/admin/giiatja/pelatihan/<%= item.id %>/delete" style="display:inline" onsubmit="return confirm('Hapus data ini?')">
                        <button class="btn btn-danger btn-xs">🗑</button>
                      </form>
                    </div>
                  </td>
                </tr>
                <% }) %>
                <% if (!pelatihanList.length) { %><tr><td colspan="9" style="text-align:center;color:#aaa;padding:20px;">Belum ada data</td></tr><% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <div class="card">
        <div class="card-header"><h3>➕ Tabel PNBP</h3></div>
        <div class="card-body">
          <form method="POST" action="/admin/giiatja/pnbp/add">
            <div class="form-grid col-4" style="margin-bottom:12px;">
              <div class="form-group"><label>Urutan</label><input type="number" min="1" name="sort_order" value="1"></div>
              <div class="form-group"><label>Periode PNBP</label><input type="text" name="periode_pnbp" required></div>
              <div class="form-group"><label>Jumlah PNBP</label><input type="text" name="jumlah_pnbp" placeholder="cth: 10.500.000"></div>
              <div class="form-group"><label>Target Realisasi</label><input type="text" name="target_realisasi" placeholder="cth: 10.000.000"></div>
              <div class="form-group"><label>Persentase</label><input type="text" name="persentase" placeholder="cth: 105%"></div>
              <div class="form-group"><label>Keterangan</label><input type="text" name="keterangan" placeholder="cth: TERCAPAI"></div>
            </div>
            <button type="submit" class="btn btn-primary btn-sm">➕ Tambah PNBP</button>
          </form>
        </div>
      </div>

      <% if (editPnbp) { %>
      <div class="edit-panel">
        <h4>✏️ Edit PNBP (ID: <%= editPnbp.id %>)</h4>
        <form method="POST" action="/admin/giiatja/pnbp/<%= editPnbp.id %>/update">
          <div class="form-grid col-4" style="margin-bottom:12px;">
            <div class="form-group"><label>Urutan</label><input type="number" min="1" name="sort_order" value="<%= editPnbp.sort_order || 1 %>"></div>
            <div class="form-group"><label>Periode PNBP</label><input type="text" name="periode_pnbp" value="<%= editPnbp.periode_pnbp || '' %>" required></div>
            <div class="form-group"><label>Jumlah PNBP</label><input type="text" name="jumlah_pnbp" value="<%= editPnbp.jumlah_pnbp || '' %>"></div>
            <div class="form-group"><label>Target Realisasi</label><input type="text" name="target_realisasi" value="<%= editPnbp.target_realisasi || '' %>"></div>
            <div class="form-group"><label>Persentase</label><input type="text" name="persentase" value="<%= editPnbp.persentase || '' %>"></div>
            <div class="form-group"><label>Keterangan</label><input type="text" name="keterangan" value="<%= editPnbp.keterangan || '' %>"></div>
          </div>
          <div style="display:flex;gap:8px;">
            <button type="submit" class="btn btn-success btn-sm">💾 Simpan</button>
            <a href="/admin/giiatja" class="btn btn-secondary btn-sm">✕ Batal</a>
          </div>
        </form>
      </div>
      <% } %>

      <div class="card">
        <div class="card-header"><h3>Daftar PNBP (<%= pnbpList.length %> data)</h3></div>
        <div class="card-body" style="padding:0;">
          <div class="table-wrap">
            <table class="admin-table">
              <thead><tr><th>No</th><th>Periode PNBP</th><th>Jumlah PNBP</th><th>Target Realisasi</th><th>Persentase</th><th>Keterangan</th><th>Aksi</th></tr></thead>
              <tbody>
                <% pnbpList.forEach((item, i) => { %>
                <tr>
                  <td><%= i + 1 %></td>
                  <td><%= item.periode_pnbp || '-' %></td>
                  <td><%= item.jumlah_pnbp || '-' %></td>
                  <td><%= item.target_realisasi || '-' %></td>
                  <td><%= item.persentase || '-' %></td>
                  <td><%= item.keterangan || '-' %></td>
                  <td>
                    <div class="actions">
                      <a href="/admin/giiatja?editPnbp=<%= item.id %>" class="btn btn-warning btn-xs">✏️</a>
                      <form method="POST" action="/admin/giiatja/pnbp/<%= item.id %>/delete" style="display:inline" onsubmit="return confirm('Hapus data ini?')">
                        <button class="btn btn-danger btn-xs">🗑</button>
                      </form>
                    </div>
                  </td>
                </tr>
                <% }) %>
                <% if (!pnbpList.length) { %><tr><td colspan="7" style="text-align:center;color:#aaa;padding:20px;">Belum ada data</td></tr><% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <div class="card">
        <div class="card-header"><h3>➕ Tabel Premi WBP</h3></div>
        <div class="card-body">
          <form method="POST" action="/admin/giiatja/premi/add">
            <div class="form-grid col-4" style="margin-bottom:12px;">
              <div class="form-group"><label>Urutan</label><input type="number" min="1" name="sort_order" value="1"></div>
              <div class="form-group"><label>No Registrasi</label><input type="text" name="no_registrasi"></div>
              <div class="form-group"><label>Nama WBP</label><input type="text" name="nama_wbp" required></div>
              <div class="form-group"><label>Jenis Kegiatan</label><input type="text" name="jenis_kegiatan"></div>
              <div class="form-group"><label>Premi yang Didapat</label><input type="text" name="premi_didapat"></div>
              <div class="form-group"><label>Keterangan</label><input type="text" name="keterangan"></div>
            </div>
            <button type="submit" class="btn btn-primary btn-sm">➕ Tambah Premi</button>
          </form>
        </div>
      </div>

      <% if (editPremi) { %>
      <div class="edit-panel">
        <h4>✏️ Edit Premi (ID: <%= editPremi.id %>)</h4>
        <form method="POST" action="/admin/giiatja/premi/<%= editPremi.id %>/update">
          <div class="form-grid col-4" style="margin-bottom:12px;">
            <div class="form-group"><label>Urutan</label><input type="number" min="1" name="sort_order" value="<%= editPremi.sort_order || 1 %>"></div>
            <div class="form-group"><label>No Registrasi</label><input type="text" name="no_registrasi" value="<%= editPremi.no_registrasi || '' %>"></div>
            <div class="form-group"><label>Nama WBP</label><input type="text" name="nama_wbp" value="<%= editPremi.nama_wbp || '' %>" required></div>
            <div class="form-group"><label>Jenis Kegiatan</label><input type="text" name="jenis_kegiatan" value="<%= editPremi.jenis_kegiatan || '' %>"></div>
            <div class="form-group"><label>Premi yang Didapat</label><input type="text" name="premi_didapat" value="<%= editPremi.premi_didapat || '' %>"></div>
            <div class="form-group"><label>Keterangan</label><input type="text" name="keterangan" value="<%= editPremi.keterangan || '' %>"></div>
          </div>
          <div style="display:flex;gap:8px;">
            <button type="submit" class="btn btn-success btn-sm">💾 Simpan</button>
            <a href="/admin/giiatja" class="btn btn-secondary btn-sm">✕ Batal</a>
          </div>
        </form>
      </div>
      <% } %>

      <div class="card">
        <div class="card-header"><h3>Daftar Premi WBP (<%= premiList.length %> data)</h3></div>
        <div class="card-body" style="padding:0;">
          <div class="table-wrap">
            <table class="admin-table">
              <thead><tr><th>No</th><th>No Registrasi</th><th>Nama WBP</th><th>Jenis Kegiatan</th><th>Premi</th><th>Keterangan</th><th>Aksi</th></tr></thead>
              <tbody>
                <% premiList.forEach((item, i) => { %>
                <tr>
                  <td><%= i + 1 %></td>
                  <td><%= item.no_registrasi || '-' %></td>
                  <td><%= item.nama_wbp || '-' %></td>
                  <td><%= item.jenis_kegiatan || '-' %></td>
                  <td><%= item.premi_didapat || '-' %></td>
                  <td><%= item.keterangan || '-' %></td>
                  <td>
                    <div class="actions">
                      <a href="/admin/giiatja?editPremi=<%= item.id %>" class="btn btn-warning btn-xs">✏️</a>
                      <form method="POST" action="/admin/giiatja/premi/<%= item.id %>/delete" style="display:inline" onsubmit="return confirm('Hapus data ini?')">
                        <button class="btn btn-danger btn-xs">🗑</button>
                      </form>
                    </div>
                  </td>
                </tr>
                <% }) %>
                <% if (!premiList.length) { %><tr><td colspan="7" style="text-align:center;color:#aaa;padding:20px;">Belum ada data</td></tr><% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>

    </div>
  </div>
</div>
</body>
</html>
